<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FF1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Touch Detector"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/instructionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Touch the screen below to analyze input"
            android:textSize="14sp"
            android:textColor="#FFB0B0B0"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FF2D2D44"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LEVEL 1: Environment Checks"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF6B6B"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/accessibilityStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Accessibility Services: Checking..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/overlayStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Overlays Detected: Checking..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/adbStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ADB/Developer Options: Checking..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FF2D2D44"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LEVEL 2: Touch Event Metadata"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFD93D"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/deviceIdStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Device ID: Waiting for touch..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/virtualDeviceStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Virtual Device: Waiting for touch..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/sourceStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Event Source: Waiting for touch..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/toolTypeStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tool Type: Waiting for touch..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/obscuredStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Window Obscured: Waiting for touch..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/accessibilityEventStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Accessibility Gesture: Waiting for touch..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/sourceAuthenticityStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Source Authenticity: Waiting for touch..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FF2D2D44"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VERDICT"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF4ECDC4"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/verdictText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No touch detected yet"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFFFF"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="#FF3D3D5C" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/touchArea"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:cardBackgroundColor="#FF0D0D1A"
            app:cardCornerRadius="12dp"
            android:layout_marginTop="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/touch_area_border">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOUCH HERE"
                    android:textSize="18sp"
                    android:textColor="#FF4ECDC4"
                    android:layout_gravity="center" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
